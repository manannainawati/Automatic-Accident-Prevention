# ============================================================
# Accident Prevention System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --- Flask ---
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=True

# --- Database ---
DATABASE_URL=sqlite:///accident_prevention.db

# --- Twilio SMS (https://www.twilio.com/) ---
# Sign up for a free trial at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# --- Emergency Contacts (comma-separated) ---
EMERGENCY_PHONE_NUMBERS=+911234567890,+919876543210
EMERGENCY_EMAIL_ADDRESSES=emergency@example.com,hospital@example.com

# --- Email SMTP (for Gmail, use App Password) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
